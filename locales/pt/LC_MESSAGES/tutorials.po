"any.whl"
msgstr ""
"➜ hatch build ────────────────────────────────────── sdist "
"────────────────────────────────────── dist/pyospackage-0.1.tar.gz "
"────────────────────────────────────── wheel "
"────────────────────────────────────── dist/pyospackage-0.1-py3-none-"
